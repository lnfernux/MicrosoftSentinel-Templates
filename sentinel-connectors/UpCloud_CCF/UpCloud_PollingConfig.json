[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2023-02-01-preview",
    "name": "UpCloudAuditLogsConnector",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "UpCloudConnectorDefinition",
      "dataType": "UpCloudAuditLogs_CL",
      "dcrConfig": {
        "streamName": "Custom-UpCloudAuditLogs_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "auth": {
        "type": "APIKey",
        "ApiKey": "{{apiKey}}",
        "ApiKeyName": "Authorization",
        "ApiKeyIdentifier": "Bearer"
      },
      "request": {
        "apiEndpoint": "https://api.upcloud.com/1.3/audit-logs",
        "httpMethod": "GET",
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "rateLimitQPS": 10,
        "queryWindowInMin": 5,
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json"
        },
        "StartTimeAttributeName": "created_after",
        "EndTimeAttributeName": "created_before",
        "queryParameters": {
          "limit": "200"
        }
      },
      "paging": {
        "pagingType": "Offset",
        "offsetParaName": "offset",
        "pageSize": 200,
        "pageSizeParameterName": "limit"
      },
      "response": {
        "eventsJsonPaths": [
          "$.audit_logs"
        ],
        "format": "json"
      }
    }
  }
]